{
  "name": "growing-in-faith",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:cf": "npx wrangler pages dev .output/public --d1=DB --compatibility-date=2024-09-23",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "db:export": "bash scripts/export-english.sh",
    "db:seed-local": "for f in scripts/d1-seed/*.sql; do npx wrangler d1 execute faithguide-bible --local --file=$f; done",
    "db:seed-remote": "for f in scripts/d1-seed/*.sql; do npx wrangler d1 execute faithguide-bible --remote --file=$f; done"
  },
  "dependencies": {
    "lucide-vue-next": "^0.577.0",
    "nuxt": "^3.21.1",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "wrangler": "^4.71.0"
  }
}
